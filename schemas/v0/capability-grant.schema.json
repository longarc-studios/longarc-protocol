{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:longarc:protocol:capability-grant:v0",
  "title": "Long Arc Capability Grant v0",
  "description": "A bounded, expiring, single-use capability grant with explicit subject, operation, scope, and budget.",
  "x-longarc-protocol": "longarc.protocol.capability-grant.v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "grantId",
    "subject",
    "capability",
    "operation",
    "scope",
    "budget",
    "issuedAt",
    "expiresAt",
    "singleUse",
    "scopeMutation",
    "status",
    "authorityRef"
  ],
  "properties": {
    "protocol": {
      "const": "longarc.protocol.capability-grant.v0"
    },
    "grantId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:/-]{0,127}$"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "enum": [
            "human",
            "service",
            "agent"
          ]
        },
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:/-]{0,127}$"
        }
      }
    },
    "capability": {
      "type": "string",
      "pattern": "^(?!.*\\*)[a-z0-9][a-z0-9._:/-]{0,127}$"
    },
    "operation": {
      "type": "string",
      "pattern": "^(?!.*\\*)[a-z0-9][a-z0-9._:/-]{0,127}$"
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?!.*\\*)[a-z0-9][a-z0-9._:/-]{0,127}$"
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "limit",
        "unit"
      ],
      "properties": {
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        },
        "unit": {
          "enum": [
            "attempt",
            "item",
            "byte",
            "second"
          ]
        }
      }
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^\\d{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12]\\d|3[01])T(?:[01]\\d|2[0-3]):[0-5]\\d:[0-5]\\dZ$"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^\\d{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12]\\d|3[01])T(?:[01]\\d|2[0-3]):[0-5]\\d:[0-5]\\dZ$"
    },
    "singleUse": {
      "const": true
    },
    "scopeMutation": {
      "const": "deny_broadening"
    },
    "status": {
      "enum": [
        "active",
        "revoked"
      ]
    },
    "authorityRef": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:/-]{0,127}$"
    }
  }
}
