{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:longarc:protocol:adapter-manifest:v0",
  "title": "Long Arc Adapter Manifest v0",
  "description": "A product-neutral declaration of one versioned adapter and its bounded capabilities.",
  "x-longarc-protocol": "longarc.protocol.adapter-manifest.v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "adapterId",
    "version",
    "displayName",
    "productNeutral",
    "policyAuthority",
    "capabilities"
  ],
  "properties": {
    "protocol": {
      "const": "longarc.protocol.adapter-manifest.v0"
    },
    "adapterId": {
      "type": "string",
      "pattern": "^(?!.*\\*)[a-z0-9][a-z0-9._:/-]{0,127}$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "productNeutral": {
      "const": true
    },
    "policyAuthority": {
      "const": "none"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "capability",
          "operations",
          "scopeKinds",
          "effectClass"
        ],
        "properties": {
          "capability": {
            "type": "string",
            "pattern": "^(?!.*\\*)[a-z0-9][a-z0-9._:/-]{0,127}$"
          },
          "operations": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^(?!.*\\*)[a-z0-9][a-z0-9._:/-]{0,127}$"
            }
          },
          "scopeKinds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^(?!.*\\*)[a-z0-9][a-z0-9._:/-]{0,127}$"
            }
          },
          "effectClass": {
            "enum": [
              "read_only",
              "state_change",
              "external_effect"
            ]
          }
        }
      }
    }
  }
}
