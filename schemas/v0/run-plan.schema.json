{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:longarc:protocol:run-plan:v0",
  "title": "Long Arc Run Plan v0",
  "description": "A finite, capability-bounded plan that explicitly carries no execution authority.",
  "x-longarc-protocol": "longarc.protocol.run-plan.v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "planId",
    "executionAuthority",
    "unknownCapabilityDisposition",
    "allowedCapabilities",
    "steps",
    "effectBudget",
    "terminalTruthPolicy"
  ],
  "properties": {
    "protocol": {
      "const": "longarc.protocol.run-plan.v0"
    },
    "planId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:/-]{0,127}$"
    },
    "executionAuthority": {
      "const": false
    },
    "unknownCapabilityDisposition": {
      "const": "deny"
    },
    "allowedCapabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?!.*\\*)[a-z0-9][a-z0-9._:/-]{0,127}$"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stepId",
          "order",
          "capability",
          "operation",
          "grantRef"
        ],
        "properties": {
          "stepId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._:/-]{0,127}$"
          },
          "order": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31
          },
          "capability": {
            "type": "string",
            "pattern": "^(?!.*\\*)[a-z0-9][a-z0-9._:/-]{0,127}$"
          },
          "operation": {
            "type": "string",
            "pattern": "^(?!.*\\*)[a-z0-9][a-z0-9._:/-]{0,127}$"
          },
          "grantRef": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._:/-]{0,127}$"
          }
        }
      }
    },
    "effectBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maximumAttempts",
        "externalEffects"
      ],
      "properties": {
        "maximumAttempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "externalEffects": {
          "type": "integer",
          "minimum": 0,
          "maximum": 32
        }
      }
    },
    "terminalTruthPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "normalizeIndeterminateToSuccess"
      ],
      "properties": {
        "allowed": {
          "const": [
            "succeeded",
            "failed",
            "indeterminate"
          ]
        },
        "normalizeIndeterminateToSuccess": {
          "const": false
        }
      }
    }
  }
}
